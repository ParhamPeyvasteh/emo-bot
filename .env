# STT (Vosk) – path to extracted model folder
VOSK_MODEL_PATH=src/models/vosk-model-small-en-us-0.15

# TTS – using Windows SAPI, no keys needed

# AI (GapGPT) – using OpenAI-compatible client
AI_API_URL=https://api.gapgpt.app/v1
AI_API_KEY=sk-bTsUCzrHKInuxDhL9Hv8NkyIfqefuwDCHdvg63w2UWvhxLiv
AI_MODEL=gapgpt-qwen-3.5
AI_TIMEOUT=30

# BLE – optional, for ESP32 control
BLE_DEVICE_ADDRESS=
USE_BLE=false