# Logging
LOG_LEVEL=INFO

# Audio
SAMPLE_RATE=16000
CHUNK_DURATION_MS=30
INPUT_DEVICE_INDEX=0

# Wake Word (Porcupine)
PORCUPINE_ACCESS_KEY=pv_your_access_key_here

# API Keys (for cloud fallback)
GAPGPT_API_KEY=your_gapgpt_api_key_here
AZURE_TTS_KEY=your_azure_tts_key_here
AZURE_TTS_REGION=eastus

# BLE
BLE_DEVICE_ADDRESS=
USE_BLE=true